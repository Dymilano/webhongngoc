# -----------------------------------------------------------------------------
# Mẫu cấu hình — CHỈ GIỮ MỘT KHỐI (không dán lặp lại).
# Clone xong:  copy .env.example .env   rồi sửa giá trị (đặc biệt JWT_SECRET).
# File .env không commit lên Git (xem .gitignore).
# -----------------------------------------------------------------------------

# Database: 1 = bật, 0 = tắt (mặc định 0 nếu không set)
USE_DB=1

# Mặc định project: sqlite (trong code, nếu không set DB_DIALECT cũng là sqlite). Đặt mysql khi dùng MySQL.
DB_DIALECT=sqlite
SQLITE_PATH=./data/ngocclothes.sqlite

PORT_SHOP=5000
PORT_ADMIN=5050

# Dùng cho npm run seed (storefront_url trong DB)
STOREFRONT_URL=http://127.0.0.1:5000

# MySQL — chỉ cần khi DB_DIALECT=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ngoc_clothes

# JWT — production: đặt JWT_SECRET dài, ngẫu nhiên
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai
# Access token (auth.js ưu tiên JWT_ACCESS_EXPIRES, không có thì dùng JWT_EXPIRES)
JWT_ACCESS_EXPIRES=15m
JWT_EXPIRES=7d
JWT_REFRESH_DAYS=30

# Seed admin (chỉ npm run seed)
ADMIN_USERNAME=admin
ADMIN_FULL_NAME=Ngoc's Admin
ADMIN_PHONE=0900000000
ADMIN_EMAIL=admin@ngoc.local
ADMIN_PASSWORD=Admin@123
