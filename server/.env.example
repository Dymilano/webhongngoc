# Sao chép thành file .env và chỉnh giá trị

# Bật/tắt database (1=bật, 0=tắt). Nếu không set sẽ mặc định 0.
USE_DB=1

# Chọn DB: mysql hoặc sqlite
DB_DIALECT=sqlite
SQLITE_PATH=./data/ngocclothes.sqlite

PORT_SHOP=5000
PORT_ADMIN=5050

# URL website bán hàng (dùng khi chạy npm run seed cho storefront_url trong DB)
STOREFRONT_URL=http://127.0.0.1:5000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ngoc_clothes

JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai
JWT_EXPIRES=7d

# Tài khoản admin mặc định (chỉ dùng khi chạy npm run seed)
ADMIN_USERNAME=admin
ADMIN_FULL_NAME=Ngoc's Admin
ADMIN_PHONE=0900000000
ADMIN_EMAIL=admin@ngoc.local
ADMIN_PASSWORD=Admin@123
